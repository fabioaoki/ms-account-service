# Copie para .env.local e ajuste (o arquivo .env.local nao vai para o Git).
# O launch "MsAccountService (credenciais .env.local)" carrega estas variaveis.
MS_ACCOUNT_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ms_account
MS_ACCOUNT_DATASOURCE_USERNAME=postgres
MS_ACCOUNT_DATASOURCE_PASSWORD=coloque_a_senha_real_do_postgres
