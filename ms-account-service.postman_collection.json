{
  "info": {
    "name": "ms-account-service",
    "description": "Microsservico de contas. Pastas alinhadas aos controllers: AccountController (contas e perfis), AnnotatorController (POST/PUT vínculo tópico-anotador + GET .../topic-annotator-links), TopicController (topicos).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
