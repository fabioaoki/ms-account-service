              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{accountId}}",
                "profiles"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profileType\": \"{{profileTypeUnlink}}\"\n}"
            },
            "description": "Remove vinculo (SPEAKER, BISHOP ou COACH). ANNOTATOR nao pode ser removido. Conta ACTIVE. Se ja nao houver vinculo, retorna 200 igual (idempotente). History com action UNLINK apenas quando removeu de fato."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('accountId')) {",
                  "  pm.environment.set('accountId', 1);",
                  "}"
                ]
              }
            },
            {
