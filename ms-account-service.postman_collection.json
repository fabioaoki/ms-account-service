      ]
    },
    {
      "name": "TopicController",
      "description": "br.com.mechanic.account.controller.topic.TopicController — criacao de topicos (apos vincular perfil nao-ANNOTATOR em AccountController).",
      "item": [
        {
          "name": "Criar topico (POST /api/v1/accounts/{accountId}/topics)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/topics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{accountId}}",
                "topics"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tema\": \"{{topicTema}}\",\n  \"contexto\": \"{{topicContexto}}\",\n  \"profile_type\": \"{{profileTypeLink}}\"\n}"
            },
            "description": "Cria registro na tabela topic. Requisitos: conta ACTIVE; profile_type diferente de ANNOTATOR; deve existir linha em account_profile para esta conta com o mesmo tipo (execute antes em AccountController: Vincular perfil com o mesmo profileTypeLink). tema obrigatorio (minimo 2 caracteres apos trim); contexto opcional. Resposta 201: id, accountId, tema, contexto, createdAt, lastUpdatedAt, status OPEN, profile_type."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('accountId')) {",
                  "  pm.environment.set('accountId', 1);",
                  "}",
                  "if (!pm.collectionVariables.get('topicTema')) {",
                  "  pm.collectionVariables.set('topicTema', 'Topico de exemplo via Postman');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.expect(pm.response.code).to.eql(201); });",
                  "const json = pm.response.json();",
                  "pm.test('Topico OPEN e ids', function () {",
                  "  pm.expect(json.id).to.be.a('number');",
                  "  pm.expect(json.accountId).to.eql(Number(pm.environment.get('accountId')));",
                  "  pm.expect(json.status).to.eql('OPEN');",
                  "  pm.expect(json.profile_type).to.eql(pm.variables.get('profileTypeLink'));",
                  "  pm.expect(json.tema).to.be.a('string');",
                  "  pm.expect(json.createdAt).to.be.a('string');",
                  "  pm.expect(json.lastUpdatedAt).to.be.a('string');",
                  "});",
                  "pm.environment.set('topicId', json.id);"
                ]
              }
            }
          ]
        }
      ]
    }
