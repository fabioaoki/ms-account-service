    {
      "name": "TopicController",
      "description": "Criacao: apenas chaves em ingles (title, context, profile_type, end_date). Sem profile_type = ANNOTATOR. PUT conforme requests atuais.",
      "item": [
        {
          "name": "Criar topico — perfil complementar (ex. SPEAKER)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/topics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{accountId}}",
                "topics"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{topicTema}}\",\n  \"context\": \"{{topicContexto}}\",\n  \"profile_type\": \"{{profileTypeLink}}\",\n  \"end_date\": \"{{topicEndDate}}\"\n}"
            },
            "description": "POST: title, context (opcional), profile_type, end_date. Conta ACTIVE; perfil vinculado; end_date na janela. Resposta 201 espelha title/context (TopicResponse)."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function toIsoLocalDateTime(d) {",
                  "  const pad = (n) => String(n).padStart(2, '0');",
                  "  return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate())",
                  "    + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes()) + ':' + pad(d.getSeconds());",
                  "}",
                  "if (!pm.environment.get('accountId')) {",
                  "  pm.environment.set('accountId', 1);",
                  "}",
                  "if (!pm.collectionVariables.get('topicTema')) {",
                  "  pm.collectionVariables.set('topicTema', 'Topico de exemplo via Postman');",
                  "}",
                  "const end = new Date();",
                  "end.setDate(end.getDate() + 1);",
                  "pm.collectionVariables.set('topicEndDate', toIsoLocalDateTime(end));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.expect(pm.response.code).to.eql(201); });",
                  "const json = pm.response.json();",
                  "pm.test('Topico OPEN, end_date e ids', function () {",
                  "  pm.expect(json.id).to.be.a('number');",
                  "  pm.expect(json.accountId).to.eql(Number(pm.environment.get('accountId')));",
                  "  pm.expect(json.status).to.eql('OPEN');",
                  "  pm.expect(json.end_date).to.be.a('string');",
                  "  pm.expect(json.profile_type).to.eql(pm.variables.get('profileTypeLink'));",
                  "  pm.expect(json.title).to.be.a('string');",
                  "  pm.expect(json.createdAt).to.be.a('string');",
                  "  pm.expect(json.lastUpdatedAt).to.be.undefined;",
                  "});",
                  "pm.environment.set('topicId', json.id);"
                ]
              }
            }
          ]
        },
