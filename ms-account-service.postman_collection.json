{
  "info": {
    "name": "ms-account-service",
    "description": "Microsservico de contas: GET/POST/PATCH /api/v1/accounts, PATCH .../deactivate e .../activate, POST/DELETE .../accounts/{id}/profiles.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.5.1"
  },
  "item": [
    {
      "name": "Criar conta (POST /api/v1/accounts)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/accounts",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "accounts"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{passwordValid}}\",\n  \"confirmPassword\": \"{{passwordValid}}\",\n  \"firstName\": \"Fabio\",\n  \"lastName\": \"Aoki\",\n  \"birthDate\": \"{{birthDate}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "function yearsAgo(years) {",
              "  const d = new Date();",
              "  d.setFullYear(d.getFullYear() - years);",
              "  const yyyy = d.getFullYear();",
              "  const mm = String(d.getMonth() + 1).padStart(2, '0');",
              "  const dd = String(d.getDate()).padStart(2, '0');",
              "  return `${yyyy}-${mm}-${dd}`;",
              "}",
              "",
              "pm.environment.set('email', 'user-' + Date.now() + '@email.com');",
              "pm.environment.set('birthDate', yearsAgo(25));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () { pm.expect(pm.response.code).to.eql(201); });",
              "const json = pm.response.json();",
              "pm.environment.set('accountId', json.id);",
              "pm.test('status ACTIVE', function () { pm.expect(json.status).to.eql('ACTIVE'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Consultar conta (GET /api/v1/accounts/{accountId})",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "accounts",
            "{{accountId}}"
          ]
        },
        "description": "Retorna accountId, name, birthDate, createdAt, status (ACTIVE ou INACTIVE) e profileTypes vinculados (ordem pelo id do account_profile). Conta inexistente: 400."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('accountId')) {",
              "  pm.environment.set('accountId', 1);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
              "const json = pm.response.json();",
              "pm.test('Campos principais', function () {",
              "  pm.expect(json.accountId).to.be.a('number');",
              "  pm.expect(json.name).to.be.a('string');",
              "  pm.expect(json.birthDate).to.be.a('string');",
              "  pm.expect(json.createdAt).to.be.a('string');",
              "  pm.expect(['ACTIVE', 'INACTIVE']).to.include(json.status);",
              "  pm.expect(json.profileTypes).to.be.an('array');",
              "  pm.expect(json.profileTypes.length).to.be.at.least(1);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Desativar conta (PATCH /api/v1/accounts/{accountId}/deactivate)",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/deactivate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "accounts",
            "{{accountId}}",
            "deactivate"
          ]
        },
        "description": "Define status INACTIVE. Sem corpo na requisicao nem na resposta (apenas 200). Idempotente: se ja INACTIVE, 200. Conta inexistente: 400."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('accountId')) {",
              "  pm.environment.set('accountId', 1);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
              "pm.test('Sem corpo JSON', function () { pm.expect(pm.response.text()).to.eql(''); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Ativar conta (PATCH /api/v1/accounts/{accountId}/activate)",
      "request": {
        "method": "PATCH",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/activate",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "accounts",
            "{{accountId}}",
            "activate"
          ]
        },
        "description": "Define status ACTIVE. Sem corpo na requisicao nem na resposta (apenas 200). Idempotente: se ja ACTIVE, 200. Conta inexistente: 400."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('accountId')) {",
              "  pm.environment.set('accountId', 1);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
              "pm.test('Sem corpo JSON', function () { pm.expect(pm.response.text()).to.eql(''); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Atualizar conta (PATCH /api/v1/accounts/{accountId})",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "accounts",
            "{{accountId}}"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"firstName\": \"Ana\",\n  \"lastName\": \"Silva\",\n  \"birthDate\": \"{{birthDateUpdate}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "function yearsAgo(years) {",
              "  const d = new Date();",
              "  d.setFullYear(d.getFullYear() - years);",
              "  const yyyy = d.getFullYear();",
              "  const mm = String(d.getMonth() + 1).padStart(2, '0');",
              "  const dd = String(d.getDate()).padStart(2, '0');",
              "  return `${yyyy}-${mm}-${dd}`;",
              "}",
              "",
              "pm.environment.set('birthDateUpdate', yearsAgo(30));",
              "if (!pm.environment.get('accountId')) {",
              "  pm.environment.set('accountId', 1);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
              "const json = pm.response.json();",
              "pm.test('lastUpdatedAt existe', function () { pm.expect(json.lastUpdatedAt).to.not.be.null; });"
            ]
          }
        }
      ]
    },
    {
      "name": "Vincular perfil (POST /api/v1/accounts/{accountId}/profiles)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/profiles",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "accounts",
            "{{accountId}}",
            "profiles"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"profileType\": \"{{profileTypeLink}}\"\n}"
        },
        "description": "Vincula um perfil extra (SPEAKER, BISHOP ou COACH). ANNOTATOR nao e permitido. Conta deve estar ACTIVE. Retorna 201 com accountId, profileId e profileType."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('accountId')) {",
              "  pm.environment.set('accountId', 1);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 201', function () { pm.expect(pm.response.code).to.eql(201); });",
              "const json = pm.response.json();",
              "pm.test('Resposta contem ids e tipo', function () {",
              "  pm.expect(json.accountId).to.be.a('number');",
              "  pm.expect(json.profileId).to.be.a('number');",
              "  pm.expect(json.profileType).to.eql(pm.variables.get('profileTypeLink'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "Desvincular perfil (DELETE /api/v1/accounts/{accountId}/profiles)",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/profiles",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "accounts",
            "{{accountId}}",
            "profiles"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"profileType\": \"{{profileTypeUnlink}}\"\n}"
        },
        "description": "Remove vinculo (SPEAKER, BISHOP ou COACH). ANNOTATOR nao pode ser removido. Conta ACTIVE. Se ja nao houver vinculo, retorna 200 igual (idempotente). History com action UNLINK apenas quando removeu de fato."
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (!pm.environment.get('accountId')) {",
              "  pm.environment.set('accountId', 1);",
              "}"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
              "const json = pm.response.json();",
              "pm.test('Resposta contem ids e tipo', function () {",
              "  pm.expect(json.accountId).to.be.a('number');",
              "  pm.expect(json.profileId).to.be.a('number');",
              "  pm.expect(json.profileType).to.eql(pm.variables.get('profileTypeUnlink'));",
              "});"
            ]
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "passwordValid",
      "value": "secret123"
    },
    {
      "key": "accountId",
      "value": "1"
    },
    {
      "key": "profileTypeLink",
      "value": "SPEAKER"
    },
    {
      "key": "profileTypeUnlink",
      "value": "SPEAKER"
    }
  ]
}
