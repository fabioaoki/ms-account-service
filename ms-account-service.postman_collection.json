        {
          "name": "Atualizar conta (PATCH /api/v1/accounts/{accountId})",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{accountId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Ana\",\n  \"lastName\": \"Silva\",\n  \"birthDate\": \"{{birthDateUpdate}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function yearsAgo(years) {",
                  "  const d = new Date();",
                  "  d.setFullYear(d.getFullYear() - years);",
                  "  const yyyy = d.getFullYear();",
                  "  const mm = String(d.getMonth() + 1).padStart(2, '0');",
                  "  const dd = String(d.getDate()).padStart(2, '0');",
                  "  return `${yyyy}-${mm}-${dd}`;",
                  "}",
                  "",
                  "pm.environment.set('birthDateUpdate', yearsAgo(30));",
                  "if (!pm.environment.get('accountId')) {",
                  "  pm.environment.set('accountId', 1);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "const json = pm.response.json();",
                  "pm.test('lastUpdatedAt existe', function () { pm.expect(json.lastUpdatedAt).to.not.be.null; });"
                ]
              }
            }
          ]
        },
        {
          "name": "Vincular perfil (POST /api/v1/accounts/{accountId}/profiles)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/profiles",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{accountId}}",
                "profiles"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"profileType\": \"{{profileTypeLink}}\"\n}"
            },
            "description": "Vincula um perfil extra (SPEAKER, BISHOP ou COACH). ANNOTATOR nao e permitido. Conta deve estar ACTIVE. Retorna 201 com accountId, profileId e profileType."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('accountId')) {",
                  "  pm.environment.set('accountId', 1);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.expect(pm.response.code).to.eql(201); });",
                  "const json = pm.response.json();",
                  "pm.test('Resposta contem ids e tipo', function () {",
                  "  pm.expect(json.accountId).to.be.a('number');",
                  "  pm.expect(json.profileId).to.be.a('number');",
                  "  pm.expect(json.profileType).to.eql(pm.variables.get('profileTypeLink'));",
                  "});"
                ]
              }
            }
          ]
        },
