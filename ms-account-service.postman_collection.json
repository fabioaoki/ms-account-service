                "type": "text/javascript",
                "exec": [
                  "function yearsAgo(years) {",
                  "  const d = new Date();",
                  "  d.setFullYear(d.getFullYear() - years);",
                  "  const yyyy = d.getFullYear();",
                  "  const mm = String(d.getMonth() + 1).padStart(2, '0');",
