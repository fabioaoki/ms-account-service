                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "pm.test('Sem corpo JSON', function () { pm.expect(pm.response.text()).to.eql(''); });"
                ]
              }
            }
          ]
        },
