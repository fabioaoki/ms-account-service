{
  "info": {
    "name": "ms-account-service",
    "description": "Microsservico de contas. Pastas alinhadas aos controllers: AccountController (contas e perfis), TopicController (topicos).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.12.0"
  },
  "item": [
    {
      "name": "AccountController",
      "description": "br.com.mechanic.account.controller.account.AccountController — cadastro, consulta, ativacao, atualizacao e vinculo de perfis.",
      "item": [
        {
          "name": "Criar conta (POST /api/v1/accounts)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{passwordValid}}\",\n  \"confirmPassword\": \"{{passwordValid}}\",\n  \"firstName\": \"Fabio\",\n  \"lastName\": \"Aoki\",\n  \"birthDate\": \"{{birthDate}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function yearsAgo(years) {",
                  "  const d = new Date();",
                  "  d.setFullYear(d.getFullYear() - years);",
                  "  const yyyy = d.getFullYear();",
                  "  const mm = String(d.getMonth() + 1).padStart(2, '0');",
                  "  const dd = String(d.getDate()).padStart(2, '0');",
                  "  return `${yyyy}-${mm}-${dd}`;",
                  "}",
                  "",
                  "pm.environment.set('email', 'user-' + Date.now() + '@email.com');",
                  "pm.environment.set('birthDate', yearsAgo(25));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 201', function () { pm.expect(pm.response.code).to.eql(201); });",
                  "const json = pm.response.json();",
                  "pm.environment.set('accountId', json.id);",
                  "pm.test('status ACTIVE', function () { pm.expect(json.status).to.eql('ACTIVE'); });"
                ]
              }
            }
          ]
        },
        {
          "name": "Consultar conta (GET /api/v1/accounts/{accountId})",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{accountId}}"
              ]
            },
            "description": "Retorna accountId, name, birthDate, createdAt, status (ACTIVE ou INACTIVE) e profileTypes vinculados (ordem pelo id do account_profile). Conta inexistente: 400."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.environment.get('accountId')) {",
                  "  pm.environment.set('accountId', 1);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Campos principais', function () {",
                  "  pm.expect(json.accountId).to.be.a('number');",
                  "  pm.expect(json.name).to.be.a('string');",
                  "  pm.expect(json.birthDate).to.be.a('string');",
                  "  pm.expect(json.createdAt).to.be.a('string');",
                  "  pm.expect(['ACTIVE', 'INACTIVE']).to.include(json.status);",
                  "  pm.expect(json.profileTypes).to.be.an('array');",
                  "  pm.expect(json.profileTypes.length).to.be.at.least(1);",
                  "});"
                ]
              }
            }
          ]
        },
