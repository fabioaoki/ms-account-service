        {
          "name": "Atualizar topico — perfil complementar (PUT /api/v1/accounts/{accountId}/topics/{topicId})",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/accounts/{{accountId}}/topics/{{topicId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "accounts",
                "{{accountId}}",
                "topics",
                "{{topicId}}"
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"{{topicTemaUpdated}}\",\n  \"context\": \"{{topicContextoUpdated}}\",\n  \"profile_type\": \"{{profileTypeLink}}\",\n  \"end_date\": \"{{topicEndDateUpdated}}\"\n}"
            },
            "description": "PUT completo (todos os campos da atualizacao). Alternativa: envie apenas um subconjunto (ex. só title e context) desde que exista pelo menos um campo. profile_type nao pode ser ANNOTATOR. end_date, se enviado, dentro de [created_at, created_at+3d]."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "function toIsoLocalDateTime(d) {",
                  "  const pad = (n) => String(n).padStart(2, '0');",
                  "  return d.getFullYear() + '-' + pad(d.getMonth() + 1) + '-' + pad(d.getDate())",
                  "    + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes()) + ':' + pad(d.getSeconds());",
                  "}",
                  "if (!pm.environment.get('accountId')) {",
                  "  pm.environment.set('accountId', 1);",
                  "}",
                  "if (!pm.environment.get('topicId')) {",
                  "  pm.environment.set('topicId', 1);",
                  "}",
                  "const end = new Date();",
                  "end.setDate(end.getDate() + 1);",
                  "pm.collectionVariables.set('topicEndDateUpdated', toIsoLocalDateTime(end));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Resposta do topico atualizado', function () {",
                  "  pm.expect(json.id).to.eql(Number(pm.environment.get('topicId')));",
                  "  pm.expect(json.accountId).to.eql(Number(pm.environment.get('accountId')));",
                  "  pm.expect(json.title).to.eql(pm.collectionVariables.get('topicTemaUpdated'));",
                  "  pm.expect(json.profile_type).to.eql(pm.variables.get('profileTypeLink'));",
                  "  pm.expect(json.end_date).to.be.a('string');",
                  "  pm.expect(json.lastUpdatedAt).to.be.a('string');",
                  "});"
                ]
              }
            }
          ]
        },
