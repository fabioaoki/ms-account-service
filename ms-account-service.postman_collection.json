              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.expect(pm.response.code).to.eql(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Resposta contem ids e tipo', function () {",
                  "  pm.expect(json.accountId).to.be.a('number');",
                  "  pm.expect(json.profileId).to.be.a('number');",
                  "  pm.expect(json.profileType).to.eql(pm.variables.get('profileTypeUnlink'));",
                  "});"
                ]
              }
            }
          ]
