{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "java",
      "name": "MsAccountService (Cursor + Docker Postgres)",
      "request": "launch",
      "mainClass": "br.com.mechanic.account.MsAccountServiceApplication",
      "projectName": "ms-account-service",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "shortenCommandLine": "auto",
      "env": {
        "SPRING_PROFILES_ACTIVE": "local",
        "MS_ACCOUNT_DATASOURCE_URL": "jdbc:postgresql://localhost:5433/annotation_app",
        "MS_ACCOUNT_DATASOURCE_USERNAME": "annotation_app",
        "MS_ACCOUNT_DATASOURCE_PASSWORD": "1234",
        "OPENAI_ENABLED": "true",
        "OPENAI_API_KEY": "${env:OPENAI_API_KEY}",
        "OPENAI_MODEL": "gpt-4o-mini",
        "OPENAI_BASE_URL": "https://api.openai.com",
        "OPENAI_ASSISTANT_ID": "asst_fME9ETCAuXCYxpikYbZj0CiT",
        "OPENAI_ASSISTANT_LINGUAGE_ID": "asst_yAlKDzutGYO1QaUdW4HNCQU3"
      }
    }
  ]
}
